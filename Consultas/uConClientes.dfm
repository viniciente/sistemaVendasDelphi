  inherited fdqry1: TFDQuery
    Active = True
    SQL.Strings = (
      'select c.clienteId,'
      '       c.nome,'
      '       c.endereco,'
      '       c.cidade,'
      '       c.bairro,'
      '       c.cep,'
      '       c.telefone,'
      '       c.email,'
      '       c.datanascimento,'
      '       c.statusId,'
      '       s.descricao AS statusNome'
      'FROM clientes c'
      'LEFT JOIN statusUsuario s ON s.statusId = c.statusId')
    Left = 319
    Top = 8
