procedure TfrmPrincipal.FormShow(Sender: TObject);
begin
  if not Assigned(oUsuarioLogado) then
   oUsuarioLogado := TUsuarioLogado.Create(dtmConexao.FDConexao);

  try
    frmLogin := TfrmLogin.Create(Self);

    if frmLogin.ShowModal = mrOk then
    begin
      lblNomeUsuario.Caption := '  USUÁRIO: ' + oUsuarioLogado.nome;

      imgAvatar.Picture.Assign(nil);

      // No seu FormShow ou após o Login
      if (oUsuarioLogado.foto <> nil) and (not oUsuarioLogado.foto.Empty) then
      begin
        imgAvatar.Picture.Assign(oUsuarioLogado.foto);
        DesenharAvatarArredondado(imgAvatar.Picture.Bitmap);
      end
      else
      begin
        // Se năo houver foto, carrega uma imagem padrăo da sua pasta de imagens
        if FileExists('C:\ProjetoDelphi\Images\usuarioPadrao.jpg') then
          imgAvatar.Picture.LoadFromFile('C:\ProjetoDelphi\Images\usuarioPadrao.jpg')
        else
          imgAvatar.Picture := nil; // Caso o arquivo năo exista, limpa o componente
      end;
    end
    else
      Application.Terminate;

  finally
    frmLogin.Release;
  end;
end;


