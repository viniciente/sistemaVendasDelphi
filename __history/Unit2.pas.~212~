procedure TfrmPrincipal.AtualizarDashBord;
begin
  try
    Screen.Cursor:=crSQLWait;

    if DtmGrafico.qryProdutoEstoque.Active then
       DtmGrafico.qryProdutoEstoque.Close;

    if DtmGrafico.qryVendaPorCliente.Active then
       DtmGrafico.qryVendaPorCliente.Close;

    if DtmGrafico.qry10ProdutosMaisVendidos.Active then
       DtmGrafico.qry10ProdutosMaisVendidos.Close;

    if DtmGrafico.qryVendaUltimaSemana.Active then
       DtmGrafico.qryVendaUltimaSemana.Close;

    DtmGrafico.qryProdutoEstoque.Open;
    DtmGrafico.qryVendaPorCliente.Open;
    DtmGrafico.qry10ProdutosMaisVendidos.Open;
    DtmGrafico.qryVendaUltimaSemana.Open;
  finally
    Screen.Cursor:=crDefault;
  end;
end;

procedure TfrmPrincipal.tmrAtualizacaoDashBordTimer(Sender: TObject);
begin
  AtualizarDashBord;
end;

procedure TfrmPrincipal.LOGOUT1Click(Sender: TObject);
begin
if MessageDlg('Deseja trocar de usuário?', mtConfirmation, [mbYes, mbNo], 0) <> mrYes then
    Exit;

  // Limpa os dados do usuário atual
  oUsuarioLogado.codigo := 0;
  oUsuarioLogado.nome   := '';
  oUsuarioLogado.senha  := '';
  oUsuarioLogado.foto.SetSize(0,0);

  // Reabre o login — mesmo fluxo do FormShow
  try
    frmLogin := TfrmLogin.Create(Self);

    if frmLogin.ShowModal = mrOk then
    begin
      // Atualiza o nome na barra inferior
      lblNomeUsuario.Caption := '  USUÁRIO: ' + oUsuarioLogado.nome;

      // Atualiza o avatar
      if (oUsuarioLogado.foto <> nil) and (not oUsuarioLogado.foto.Empty) then
        DesenharAvatarArredondado(oUsuarioLogado.foto)
      else if (imgAvatar.Picture.Graphic <> nil) and
        (imgAvatar.Picture.Bitmap.Width > 0) then
          DesenharAvatarArredondado(imgAvatar.Picture.Bitmap);

      // Atualiza o dashboard com os dados do novo usuário
      AtualizarDashBord;
    end
    else
    begin
      // Usuário fechou o login sem entrar — encerra o sistema
      Application.Terminate;
    end;

  finally
    frmLogin.Release;
  end;
end;

