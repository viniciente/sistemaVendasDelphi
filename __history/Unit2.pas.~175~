procedure TfrmPrincipal.AtualizarDashBord;
begin
  try
    Screen.Cursor:=crSQLWait;

    if DtmGrafico.qryProdutoEstoque.Active then
       DtmGrafico.qryProdutoEstoque.Close;

    if DtmGrafico.qryVendaPorCliente.Active then
       DtmGrafico.qryVendaPorCliente.Close;

    if DtmGrafico.qry10ProdutosMaisVendidos.Active then
       DtmGrafico.qry10ProdutosMaisVendidos.Close;

    if DtmGrafico.qryVendaUltimaSemana.Active then
       DtmGrafico.qryVendaUltimaSemana.Close;

    DtmGrafico.qryProdutoEstoque.Open;
    DtmGrafico.qryVendaPorCliente.Open;
    DtmGrafico.qry10ProdutosMaisVendidos.Open;
    DtmGrafico.qryVendaUltimaSemana.Open;
  finally
    Screen.Cursor:=crDefault;
  end;
end;

procedure TfrmPrincipal.tmrAtualizacaoDashBordTimer(Sender: TObject);
