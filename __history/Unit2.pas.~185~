procedure TfrmPrincipal.FormShow(Sender: TObject);
var
  sCaminhoImagem: string;
begin
  if not Assigned(oUsuarioLogado) then
   oUsuarioLogado := TUsuarioLogado.Create(dtmConexao.FDConexao);

  try
    frmLogin := TfrmLogin.Create(Self);

    if frmLogin.ShowModal = mrOk then
    begin
      lblNomeUsuario.Caption := '  USUÁRIO: ' + oUsuarioLogado.nome;

      // No seu FormShow ou após o Login
      if (oUsuarioLogado.foto <> nil) and (not oUsuarioLogado.foto.Empty) then
      begin
        imgAvatar.Picture.Assign(oUsuarioLogado.foto);
        DesenharAvatarArredondado(oUsuarioLogado.foto);  // Aplicar efeito circular
      end
      else
      begin
        // Usar caminho relativo ŕ aplicaçăo
        sCaminhoImagem := ExtractFilePath(Application.ExeName) + '\Images\usuarioPadrao.jpg';

        if FileExists(sCaminhoImagem) then
        begin
          try
            imgAvatar.Picture.LoadFromFile(sCaminhoImagem);
            DesenharAvatarArredondado(imgAvatar.Picture.Bitmap);  // Aplicar efeito circular
          except
            on E: Exception do
              ShowMessage('Erro ao carregar imagem: ' + E.Message);
          end;
        end
        else
          imgAvatar.Picture := nil;
      end;
    end
    else
      Application.Terminate;

  finally
    frmLogin.Release;
  end;
end;


