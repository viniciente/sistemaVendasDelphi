  object QryVenda: TFDQuery
    Active = True
    Connection = dtmConexao.fdConexao
    SQL.Strings = (
      'SELECT vendas.vendaId,'
      '       vendas.clienteId,'
      '       clientes.nome,'
      '       vendas.dataVenda,'
      '       cast(vendas.totalVenda as numeric (18,3)) totalVenda'
      '  FROM Vendas'
      
        '       INNER JOIN clientes on clientes.clienteId = vendas.client' +
        'eId'
      ' WHERE vendas.dataVenda BETWEEN :DATAINICIO AND :DATAFIM'
      ' ORDER BY vendas.dataVenda, clienteId')
    Left = 624
    Top = 328
    ParamData = <
      item
        Name = 'DATAINICIO'
        DataType = ftDate
        ParamType = ptInput
        Value = Null
      end
      item
        Name = 'DATAFIM'
        DataType = ftDate
        ParamType = ptInput
      end>
