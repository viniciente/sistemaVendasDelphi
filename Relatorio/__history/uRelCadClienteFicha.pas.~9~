procedure TfrmRelCadClienteFicha.RLBand2BeforePrint(Sender: TObject; var PrintIt: Boolean);
begin
  // Usamos o campo TipoPessoa que veio do seu JOIN na SQL
  if Trim(QryCliente.FieldByName('tipoPessoa').AsString) = 'Física' then
    RLLabel14.Caption := 'CPF:'
  else if Trim(QryCliente.FieldByName('tipoPessoa').AsString) = 'Jurídica' then
    RLLabel14.Caption := 'CNPJ:'
  else
    RLLabel14.Caption := 'Doc:';
end;

