  object QryCliente: TFDQuery
    Active = True
    Connection = dtmConexao.fdConexao
    SQL.Strings = (
      'SELECT c.clienteId,'
      '       c.nome,'
      '       c.email,'
      '       c.telefone,'
      '       s.descricao AS status_desc,'
      '       p.descricao AS pessoa'
      '  FROM clientes c'
      '  LEFT JOIN statusClientes s  ON (s.statusId = c.statusId)'
      '  LEFT JOIN tipoPessoa p ON (p.pessoaId = c.pessoaId)'
      ' ORDER BY c.nome')
