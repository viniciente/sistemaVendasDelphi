{$REGION 'Override'}
function TfrmProVendas.Apagar: Boolean;
begin
  Result := False;
  if oVenda.Selecionar(FDQuery1.FieldByName('vendaId').AsInteger, dtmVendas.cdsItensVendas) then
    Result := oVenda.Apagar;
end;

function TfrmProVendas.Gravar(EstadoDoCadastro: TEstadoDoCadastro): boolean;
var
  vMotivo: string;
  vClienteCheck: TCliente;
begin
  vClienteCheck := TCliente.Create(dtmConexao.FDConexao);
  try
    if vClienteCheck.Selecionar(lkpCliente.KeyValue) then
    begin
      if not vClienteCheck.PodeComprar(vMotivo) then
      begin
        Application.MessageBox(PChar('Este cliente possui restrições:' + #13#10 + vMotivo),
          'Venda Bloqueada', MB_OK + MB_ICONSTOP);
        Result := False;
        Exit;
      end;
    end;
  finally
    vClienteCheck.Free;
  end;

  if edtVendaId.Text <> EmptyStr then
     oVenda.VendaId := StrToInt(edtVendaId.Text)
  else
     oVenda.VendaId := 0;

  oVenda.ClienteId  := lkpCliente.KeyValue;
  oVenda.DataVenda  := edtDataVenda.Date;

  // O edtValorTotal já deve ter a soma calculada na Grid
  oVenda.TotalVenda := edtValorTotal.Value;

  if (EstadoDoCadastro = ecInserir) then
  begin
     oVenda.VendaId := oVenda.Inserir(dtmVendas.cdsItensVendas);
  end
  else if (EstadoDoCadastro = ecAlterar) then
     oVenda.Atualizar(dtmVendas.cdsItensVendas);

  // relatório também aceite quantidade 1 para serviços
  frmRelProVenda := TfrmRelProVenda.Create(self);
  try
    frmRelProVenda.QryVenda.Close;
    frmRelProVenda.QryVenda.ParamByName('VendaId').AsInteger := oVenda.VendaId;
    frmRelProVenda.QryVenda.Open;

    frmRelProVenda.QryVendasItens.Close;
    frmRelProVenda.QryVendasItens.ParamByName('VendaId').AsInteger := oVenda.VendaId;
    frmRelProVenda.QryVendasItens.Open;

    frmRelProVenda.Relatorio.PreviewModal;
  finally
    frmRelProVenda.Release;
  end;

  Result := True;
end;


procedure TfrmProVendas.lkpProdutoClick(Sender: TObject);
begin
  // Verificamos o valor diretamente na query que está no Data Module
  // categoriaId 46 = Serviços
  if dtmVendas.QryProdutos.FieldByName('categoriasId').AsInteger = 46 then
  begin
    // Esconde o que não faz sentido para serviço
    edtQuantidade.Visible := False;
    lblQuantidade.Visible := False;
    edtTotalProduto.Visible := False;
    lblTotalProduto.Visible := False;

    // Muda a Label para algo mais direto
    lblValorUnitario.Caption := 'Valor do Serviço';

    // Força a quantidade para 1 no objeto ou na variável de cálculo
    edtQuantidade.Value := 1;
  end
  else
  begin
    // Restaura o padrão para produtos físicos
    edtQuantidade.Visible := True;
    lblQuantidade.Visible := True;
    edtTotalProduto.Visible := True;
    lblTotalProduto.Visible := True;
    lblValorUnitario.Caption := 'Valor Unitário';
  end;
end;

procedure TfrmProVendas.lkpProdutoExit(Sender: TObject);
begin
  inherited;
  if TDBLookupComboBox(Sender).KeyValue<>null then begin
    edtValorUnitario.Value:=dtmVendas.QryProdutos.FieldByName('valor').AsFloat;
    edtQuantidade.Value:=1;
    edtTotalProduto.Value:=TotalizarProduto(edtValorUnitario.Value, edtQuantidade.Value);
  end;
end;

