unit uFuncaoCriptografia;

interface

uses Winapi.Windows, Winapi.Messages, System.SysUtils, System.Variants, System.Classes, Vcl.Graphics, Vcl.Controls,
     Vcl.Forms, Vcl.Dialogs;

function Criptografar (const aEntrada:String): string;
function Descriptografar (const aEntrada:string):string;

implementation

function Criptografar (const aEntrada:String): string;
var i, iQldeEnt, iIntervalo:Integer;
    sSaida:string;
    sProximoCaracter:String;
begin
  iIntervalo:= 6;
  i         := 0;
  iQldeEnt  := 0;

  if (aEntrada <> EmptyStr) then
  begin
    iQldeEnt := Length(aEntrada);
    for i := iQldeEnt downto 1 do //faz o loop inverso
    begin
      sProximoCaracter := Copy(aEntrada, i, 1);
      sSaida := sSaida + (Char(Ord(sProximoCaracter[1])+iIntervalo));
    end;
  end;

  Result:= sSaida;
end;

function Descriptografar (const aEntrada:string):string;
var i, iQtdEnt, iIntervalo:Integer;
    sSaida:string;
    sProximoCaracter:string;
begin
  iIntervalo := 6;
  i          := 0;
  iQtdEnt    := 0;
  if (aEntrada <> EmptyStr) then begin
    iQtdEnt := Length(aEntrada);

    for i := iQtdEnt downto 1 do
    begin
      sProximoCaracter := Copy(aEntrada, i, 1);
      sSaida := sSaida + (Char(Ord(sProximoCaracter[1])-iIntervalo));
    end;
  end;

  Result:= sSaida;
end;

end.
