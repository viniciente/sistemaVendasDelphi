function TfrmCadCliente.Gravar(EstadoDoCadastro: TEstadoDoCadastro): Boolean;
var
  vDocLimpo: string;
begin
  //remove a formatação do texto, (ponto, traço, barra)
  vDocLimpo := TFuncao.SomenteNumeros(edtCPFCNPJ.Text);

  //Validação do cpf
  if lkpPessoa.KeyValue = 1 then // Pessoa Física
  begin
    if not TFuncao.ValidarCPF(vDocLimpo) then
    begin
      MessageDlg('CPF Inválido! Por favor, verifique os números.', mtError, [mbOK], 0);
      edtCPFCNPJ.SetFocus;
      Result := False;
      Exit;
    end;
  end
  //validação do CNPJ
  else if lkpPessoa.KeyValue = 2 then // Pessoa Jurídica
  begin
    if not TFuncao.ValidarCNPJ(vDocLimpo) then
    begin
      MessageDlg('CNPJ Inválido! Por favor, verifique os números.', mtError, [mbOK], 0);
      edtCPFCNPJ.SetFocus;
      Result := False;
      Exit;
    end;
  end;

  //verifica se o campos do email esta vazio ou n
  if (edtEmail.Text <> '') and (not EmailValido(edtEmail.Text)) then
  begin
    MessageDlg('Por favor, insira um e-mail válido!' + #13 +
               'Exemplo: usuario@gmail.com', mtWarning, [mbOK], 0);
    edtEmail.SetFocus;
    Abort; // Para a execução e não grava
  end;

  // Se o código chegou aqui, significa que o CPF/CNPJ é válido.

  // Tratamento do ID
  if edtClienteId.Text <> EmptyStr then
    oCliente.codigo := StrToInt(edtClienteId.Text)
  else
    oCliente.codigo := 0;

  // Atribuição de campos de texto
  oCliente.nome           := edtNome.Text;
  oCliente.endereco       := edtEndereco.Text;
  oCliente.estado         := edtEstado.Text;
  oCliente.bairro         := edtBairro.Text;
  oCliente.cidade         := edtCidade.Text;
  oCliente.email          := edtEmail.Text;
  oCliente.dataNascimento := edtDataNascimento.Date;
  oCliente.numero         := TFuncao.SomenteNumeros(edtNumero.Text);

  oCliente.cep      := TFuncao.SomenteNumeros(edtCEP.Text);
  oCliente.telefone := TFuncao.SomenteNumeros(edtTelefone.Text);
  oCliente.cpf_cnpj := vDocLimpo; // Já usamos a variável que limpamos lá no topo

  // Uso do tipo pessoa
  if lkpPessoa.KeyValue <> null then
    oCliente.pessoaId := lkpPessoa.KeyValue
  else
    oCliente.pessoaId := 1;

  // Uso do status
  if lpkStatus.KeyValue <> Null then
    oCliente.statusId := lpkStatus.KeyValue
  else
    oCliente.statusId := 1;

  // Execução da gravação
  if (EstadoDoCadastro = ecInserir) then
    Result := oCliente.Inserir
  else if (EstadoDoCadastro = ecAlterar) then
    Result := oCliente.Atualizar;
end;

