procedure TfrmCadCliente.edtCEPChange(Sender: TObject);
var
  Edit: TEdit;
begin
  Edit := TEdit(Sender);

  Edit.OnChange := nil;
  try
    Edit.MaxLength := 9;

    Edit.Text := TFuncao.FormatarCEP(Edit.Text);

    Edit.SelStart := Length(Edit.Text);
  finally
    Edit.OnChange := edtCEPChange;
  end;
end;

procedure TfrmCadCliente.edtCEPExit(Sender: TObject);
var
  HTTP: THTTPClient;
  Response: IHTTPResponse;
  JSONObj: TJSONObject;
  CEP, URL: string;
begin
  CEP := Trim(edtCEP.Text);
  // Limpa máscara (deixa só números)
  CEP := StringReplace(CEP, '-', '', [rfReplaceAll]);
  CEP := StringReplace(CEP, '.', '', [rfReplaceAll]);

  if Length(CEP) <> 8 then Exit;

  URL := 'https://viacep.com.br/ws/' + CEP + '/json/';
  HTTP := THTTPClient.Create;
  try
    try
      Response := HTTP.Get(URL);

      if Response.StatusCode = 200 then
      begin
        JSONObj := TJSONObject.ParseJSONValue(Response.ContentAsString) as TJSONObject;
        try
          if Assigned(JSONObj) then
          begin
            // A API do ViaCEP retorna "erro: true" se o CEP for válido mas não existir
            if JSONObj.GetValue('erro') <> nil then
            begin
              ShowMessage('CEP não encontrado!');
              Exit;
            end;

            // Preenche os campos (Use os nomes dos seus componentes aqui)
            edtEndereco.Text := JSONObj.GetValue('logradouro').Value;
            edtBairro.Text   := JSONObj.GetValue('bairro').Value;
            edtCidade.Text   := JSONObj.GetValue('localidade').Value;
            edtEstado.Text  := JSONObj.GetValue('uf').Value;

            //edtNumero.SetFocus;

          end;
        finally
          JSONObj.Free;
        end;
      end;
    except
      on E: Exception do
        ShowMessage('Falha ao conectar com ViaCEP: ' + E.Message);
    end;
  finally
    HTTP.Free;
  end;
end;

