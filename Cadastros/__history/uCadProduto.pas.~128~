procedure TfrmCadProduto.dbgrdListagemDrawColumnCell(Sender: TObject; const Rect: TRect;
  DataCol: Integer; Column: TColumn; State: TGridDrawState);
var
  Bitmap: TBitmap;
  Stream: TMemoryStream;
begin
  inherited;
  // Verificamos se a coluna atual é a da Foto (substitua 'foto' pelo nome real da sua coluna)
  if Column.FieldName = 'foto' then
  begin
    // Limpamos a célula para não ficar com lixo visual
    dbgrdListagem.Canvas.FillRect(Rect);

    // Só tentamos desenhar se houver algo gravado no campo
    if not FDQuery1.FieldByName('foto').IsNull then
    begin
      Bitmap := TBitmap.Create;
      Stream := TMemoryStream.Create;
      try
        // Extraímos os dados do campo BLOB para o Stream
        TBlobField(FDQuery1.FieldByName('foto')).SaveToStream(Stream);
        Stream.Position := 0;

        // Carregamos no Bitmap
        Bitmap.LoadFromStream(Stream);

        // Desenhamos a imagem centralizada no "quadradinho" (Rect) da célula
        dbgrdListagem.Canvas.StretchDraw(Rect, Bitmap);
      finally
        Stream.Free;
        Bitmap.Free;
      end;
    end;
  end;
end;

procedure TfrmCadProduto.dsListagemDataChange(Sender: TObject; Field: TField);
var
  Stream: TMemoryStream;
  Bitmap: TBitmap;
begin
  if FDQuery1.IsEmpty then Exit;

  // Limpa a imagem anterior corretamente
  imgVisualizacao.Picture.Assign(nil);

  if not FDQuery1.FieldByName('foto').IsNull then
  begin
    Stream := TMemoryStream.Create;
    Bitmap := TBitmap.Create;
    try
      TBlobField(FDQuery1.FieldByName('foto')).SaveToStream(Stream);

      if Stream.Size > 0 then
      begin
        Stream.Position := 0;
        try
          // Usa Bitmap intermediario - LoadFromStream direto no Picture nao funciona com BLOB do SQL Server
          Bitmap.LoadFromStream(Stream);
          imgVisualizacao.Picture.Assign(Bitmap);
          imgVisualizacao.Visible := True;
        except
          imgVisualizacao.Picture.Assign(nil);
          imgVisualizacao.Visible := False;
        end;
      end;
    finally
      Bitmap.Free;
      Stream.Free;
    end;
  end
  else
    // Sem foto: esconde o componente e deixa o grid normal
    imgVisualizacao.Visible := False;
end;

procedure TfrmCadProduto.dsListagemStateChange(Sender: TObject);
begin
  inherited;
  ControlarBotoes;
end;

procedure TfrmCadProduto.FDQuery1AfterScroll(DataSet: TDataSet);
begin
  // Delega para o DataChange que trata a imagem corretamente
  dsListagemDataChange(dsListagem, nil);
  AjustarInterfacePorCategoria;
end;
procedure TfrmCadProduto.FormActivate(Sender: TObject);
begin
  inherited;
  QryCategoria.Open;
  QryFornecedor.Open;
end;

procedure TfrmCadProduto.FormClose(Sender: TObject; var Action: TCloseAction);
begin
  dsListagem.OnDataChange := nil;
  inherited;
  QryCategoria.Close;
  if Assigned(oProduto) then
     FreeAndNil(oProduto);
end;

procedure TfrmCadProduto.FormCreate(Sender: TObject);
begin
  FCarregando := True;
  inherited;
  oProduto := TProduto.Create(dtmConexao.FDConexao);
  IndiceAtual := 'nome';
end;

procedure TfrmCadProduto.FormShow(Sender: TObject);
begin
  inherited;

  //garante que a Query está aberta
  if not FDQuery1.Active then
    FDQuery1.Open;

  //liga o evento
  dsListagem.OnDataChange := dsListagemDataChange;

  //força a execução para o registro que já está selecionado
  dsListagemDataChange(dsListagem, nil);
end;

procedure TfrmCadProduto.AjustarInterfacePorCategoria;
begin
  // Verificamos se a categoria selecionada é "Serviços"
  if lkpCategoria.Text = 'Serviços' then
  begin
    //Esconde campos Quantidade e Foto
    edtQuantidade.Visible := False;
    lblQuantidade.Visible := False;
    pnlFotoProduto.Visible := False;

    // Altera a Label
    lblFornecedor.Caption := 'Empresa Prestadora';

    pnlFundo.Color := $00FFF5EE; // Um azul bem claro ou cinza sutil
  end
  else
  begin
    // Volta ao padrão para Itens/Produtos
    edtQuantidade.Visible := True;
    lblQuantidade.Visible := True;
    lblFornecedor.Caption := 'Fornecedor';
    pnlFundo.Color := clBtnFace;
  end;
end;

end.

