procedure TfrmCadCliente.FiltrarPorStatus(AStatusID: Integer);
var
  SQLFinal: string;
begin
  // 1. Pegamos o SQL limpo (sem order by) da lógica que vocę já tem
  SQLFinal := SelectOriginal;

  // 2. Adicionamos o filtro do Status de forma direta
  // Como o seu SelectOriginal năo tem WHERE, usamos WHERE direto
  SQLFinal := SQLFinal + ' WHERE cl.statusId = ' + IntToStr(AStatusID);

  // 3. Aplicamos ŕ Query
  FDQuery1.Close;
  FDQuery1.SQL.Text := SQLFinal;
  FDQuery1.Open;

  // 4. Feedback visual (Opcional)
  pgcPrincipal.ActivePage := tsListagem;
  lblIndice.Caption := 'Filtrado por Status';
end;

