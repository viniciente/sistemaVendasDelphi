        'SELECT TOP 10 CONVERT(VARCHAR, vi.produtoId) + '#39'-'#39'+p.nome AS Lab' +
        'el,'
      '  SUM(vi.totalProduto) AS Value'
      'FROM vendasItens AS vi'
      '  INNER JOIN produtos AS P ON p.produtoId = vi.produtoId'
