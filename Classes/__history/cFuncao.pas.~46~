class function TFuncao.FormatarCPFCNPJ(const V: string): string;
var S: string;
begin
  S := Trim(V);
  if Length(S) = 11 then // CPF: 000.000.000-00
    Result := Copy(S,1,3)+'.'+Copy(S,4,3)+'.'+Copy(S,7,3)+'-'+Copy(S,10,2)
  else if Length(S) = 14 then // CNPJ: 00.000.000/0000-00
    Result := Copy(S,1,2)+'.'+Copy(S,3,3)+'.'+Copy(S,6,3)+'/'+Copy(S,9,4)+'-'+Copy(S,13,2)
  else
    Result := S;
end;

class function TFuncao.FormatarTelefone(const V: string): string;
var S: string;
begin
  S := Trim(V);
  if (Length(S) = 11) and (S[1] = '0') then       // 0800 000 0000
    Result := Copy(S,1,4)+' '+Copy(S,5,3)+' '+Copy(S,8,4)
  else if Length(S) = 11 then                       // (11) 98888-7777
    Result := '('+Copy(S,1,2)+') '+Copy(S,3,5)+'-'+Copy(S,8,4)
  else if Length(S) = 10 then                       // (11) 3333-4444
    Result := '('+Copy(S,1,2)+') '+Copy(S,3,4)+'-'+Copy(S,7,4)
  else
    Result := S;
end;

class function TFuncao.FormatarCEP(const V: string): string;
var S: string;
begin
  S := Trim(V);
  if Length(S) = 8 then  // 00000-000
    Result := Copy(S,1,5)+'-'+Copy(S,6,3)
  else
    Result := S;
end;

class function TFuncao.FormatarCNPJ(const V: string): string;
var S: string;
begin
  S := Trim(V);
  if Length(S) = 14 then
    Result := Copy(S,1,2)+'.'+Copy(S,3,3)+'.'+Copy(S,6,3)+'/'+Copy(S,9,4)+'-'+Copy(S,13,2)
  else
    Result := S;
end;

{$REGION 'VALIDAÇĂO CPF/CNPJ'}

class function TFuncao.ValidarCPF(aCPF: string): Boolean;
var
  d1, d2, n: array[1..11] of Integer;
  i, somatorio: Integer;
begin
  Result := False;
  if Length(aCPF) <> 11 then Exit;
  if (aCPF = '00000000000') or (aCPF = '11111111111') then Exit;

  try
    for i := 1 to 11 do n[i] := StrToInt(aCPF[i]);

    // Cálculo do 1ş Dígito
    somatorio := n[1]*10 + n[2]*9 + n[3]*8 + n[4]*7 + n[5]*6 + n[6]*5 + n[7]*4 + n[8]*3 + n[9]*2;
    d1[1] := 11 - (somatorio mod 11);
    if d1[1] >= 10 then d1[1] := 0;

    // Cálculo do 2ş Dígito
    somatorio := n[1]*11 + n[2]*10 + n[3]*9 + n[4]*8 + n[5]*7 + n[6]*6 + n[7]*5 + n[8]*4 + n[9]*3 + d1[1]*2;
    d2[1] := 11 - (somatorio mod 11);
    if d2[1] >= 10 then d2[1] := 0;

    Result := (n[10] = d1[1]) and (n[11] = d2[1]);
  except
    Result := False;
  end;
end;

class function TFuncao.ValidarCNPJ(aCNPJ: string): Boolean;
var
  v: array[1..2] of Integer;
  s, i, p, j: Integer;
begin
  Result := False;
  if (Length(aCNPJ) <> 14) then Exit;

  try
    // usa 'j' para controlar o loop
    for j := 1 to 2 do
    begin
      s := 0;
      p := 2;

      // O loop interno percorre os dígitos para o cálculo
      for i := (11 + j) downto 1 do
      begin
        s := s + (StrToInt(aCNPJ[i]) * p);
        Inc(p);
        if p > 9 then p := 2;
      end;

      v[j] := 11 - (s mod 11);
      if v[j] >= 10 then v[j] := 0;
    end;

    // compara os dígitos verificadores calculados com os reais (posiçőes 13 e 14)
    Result := (StrToInt(aCNPJ[13]) = v[1]) and (StrToInt(aCNPJ[14]) = v[2]);
  except
    Result := False;
  end;
end;

