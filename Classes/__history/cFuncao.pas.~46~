{$REGION'LIMPAR IMAGEM'}

class procedure TFuncao.LimparImagem(var aImage:TImage);
begin
  if aImage <> nil then
  begin
    aImage.Picture := nil; // Limpa a imagem

    // Se a imagem estiver dentro de um Painel, garantimos que
    // o painel continue visível e o componente também.
    aImage.Visible := True;

    if aImage.Parent is TPanel then
      TPanel(aImage.Parent).Visible := True;
  end;
end;

