{$REGION 'FUCTION FORMATARCEP'}
function TfrmCadCliente.FormatarCEP(const Value: string): string;
var
  S: string;
  i: Integer;
begin
  // Remove tudo que n o for n mero
  S := '';
  for i := 1 to Length(Value) do
    if Value[i] in ['0'..'9'] then
      S := S + Value[i];

  // limita a 8 digitos
  if Length(S) > 8 then
    S := Copy(S, 1, 8);

  //mascara
  if Length(S) > 5 then
    Insert('-', S, 6);

  Result := S;
end;

{$ENDREGION}

